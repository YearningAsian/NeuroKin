# ── NeuroKin Backend Environment ────────────────────────────────
# Set to 0 once Snowflake is configured. Keep 1 for local demo.
DEMO_MODE=1

# Set to 1 to generate recommendation explanations via Cortex COMPLETE.
# Keep 0 for lower latency (uses deterministic template explanations).
ENABLE_CORTEX_EXPLANATIONS=0

# ── Snowflake Connection ───────────────────────────────────────
# HOW TO FIND YOUR ACCOUNT LOCATOR:
#   1. Log in to Snowsight (https://app.snowflake.com)
#   2. Bottom-left corner → click your account name
#   3. Hover over the account → click the copy icon next to "Account"
#   4. You'll get something like: xy12345.us-east-2.aws
#      (the part BEFORE .snowflakecomputing.com)
SNOWFLAKE_ACCOUNT=xy12345.us-east-2.aws
SNOWFLAKE_USER=NEUROKIN_USER
SNOWFLAKE_PASSWORD=CHANGE_ME
SNOWFLAKE_DATABASE=NEUROKIN_DB
SNOWFLAKE_SCHEMA=PUBLIC
SNOWFLAKE_WAREHOUSE=NEUROKIN_WH
SNOWFLAKE_ROLE=NEUROKIN_APP_ROLE
SNOWFLAKE_POOL_SIZE=4

# ── Encryption ─────────────────────────────────────────────────
# Fernet key for journal text encryption at rest.
# Generate with: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=
